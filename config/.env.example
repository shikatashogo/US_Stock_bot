# ============================================================
# US Stock Trading Bot - 環境変数テンプレート
# ============================================================
# このファイルを .env にコピーして、実際の値を入力してください
# cp config/.env.example config/.env
#
# .env ファイルは絶対にGit等に公開しないでください！
# ============================================================

# -----------------------------------------------------------
# IBKR（Interactive Brokers）設定
# TWS または IB Gateway を起動した状態で使用します
# -----------------------------------------------------------
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
IBKR_ACCOUNT=              # IBKR口座番号（例: U1234567）
IBKR_PAPER_TRADING=true    # ペーパートレード: true / 本番: false

# -----------------------------------------------------------
# Telegram Bot 通知設定（LINE Notifyは2025/3/31終了のため代替）
# 設定方法:
#   1. Telegramで @BotFather を開く
#   2. /newbot でBot作成 → トークンを取得
#   3. 自分のBotにメッセージを送る
#   4. https://api.telegram.org/botTOKEN/getUpdates にアクセス
#      → "id" の数字が TELEGRAM_CHAT_ID
# -----------------------------------------------------------
TELEGRAM_BOT_TOKEN=        # BotFatherから取得したトークン（例: 123456:ABCdef...）
TELEGRAM_CHAT_ID=          # 自分のChat ID（例: 987654321）

# -----------------------------------------------------------
# AI戦略最適化（Claude API）
# -----------------------------------------------------------
ANTHROPIC_API_KEY=         # AnthropicのAPIキー

# -----------------------------------------------------------
# オプション: 追加データソース
# -----------------------------------------------------------
ALPHA_VANTAGE_API_KEY=     # Alpha Vantage APIキー（オプション）
FINNHUB_API_KEY=           # Finnhub APIキー（オプション）

# -----------------------------------------------------------
# 為替レート（JPY/USD）
# 初期資金をUSDに換算するために使用
# -----------------------------------------------------------
JPY_USD_RATE=0.0066        # 例: 1円 = 0.0066ドル（約152円/ドル）
