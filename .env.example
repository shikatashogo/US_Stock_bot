# ============================================================
# 株式推奨Bot 環境変数設定
# このファイルをコピーして .env という名前で保存し、値を設定する
# cp .env.example .env
# ============================================================

# Anthropic API キー（Claude AIによる詳細分析に必要）
# 取得方法: https://console.anthropic.com → API Keys → Create Key
# 未設定の場合はルールベースのフォールバックレポートを使用
ANTHROPIC_API_KEY=sk-ant-ここにキーを貼り付け

# LINE通知（オプション・未設定でも動作可）
# LINE_CHANNEL_ACCESS_TOKEN=
# LINE_USER_ID=
